# Circly Frontend - Environment Variables Template

# API URL
EXPO_PUBLIC_API_URL=http://localhost:8002/api/v1

# Environment
EXPO_PUBLIC_ENV=development
EXPO_PUBLIC_AUTH_MODE=supabase

# Supabase Auth (required when EXPO_PUBLIC_AUTH_MODE=supabase)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
