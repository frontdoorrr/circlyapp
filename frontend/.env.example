# Circly Frontend - Environment Variables Template

# API URL
EXPO_PUBLIC_API_URL=http://localhost:8002/api/v1

# Environment
EXPO_PUBLIC_ENV=development
EXPO_PUBLIC_AUTH_MODE=supabase

# Universal/App Link 도메인의 DNS와 association 파일 배포를 마친 뒤 설정하세요.
# 미설정 시 설치된 앱용 circly:// 초대 링크를 사용합니다.
# EXPO_PUBLIC_INVITE_BASE_URL=https://circly.app

# Supabase Auth (required when EXPO_PUBLIC_AUTH_MODE=supabase)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Legacy fallback only
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# RevenueCat public SDK keys (구매 테스트는 Expo Go가 아닌 Development Build 필요)
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_your-ios-public-sdk-key
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_your-android-public-sdk-key
# RevenueCat Test Store를 사용하는 로컬 개발 환경에서만 선택적으로 설정
# EXPO_PUBLIC_REVENUECAT_TEST_API_KEY=test_your-test-store-public-sdk-key
